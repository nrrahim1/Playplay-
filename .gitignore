<!DOCTYPE html>
<html>
<head>
<title>MyTube</title>

<style>

body{
font-family:Arial;
margin:0;
background:#f2f2f2;
}

.header{
background:red;
color:white;
padding:15px;
font-size:22px;
}

.search{
padding:10px;
background:white;
}

.search input{
width:80%;
padding:8px;
}

.container{
padding:10px;
}

.video{
background:white;
margin-bottom:10px;
padding:8px;
border-radius:6px;
}

video{
width:100%;
}

.title{
font-size:16px;
margin-top:5px;
}

</style>

</head>

<body>

<div class="header">
MyTube
</div>

<div class="search">
<input type="text" placeholder="Search video">
</div>

<div class="container">

<div class="video">
<video controls>
<source src="video1.mp4" type="video/mp4">
</video>
<div class="title">আমার প্রথম ভিডিও</div>
</div>

<div class="video">
<video controls>
<source src="video2.mp4" type="video/mp4">
</video>
<div class="title">ভ্রমণের ভিডিও</div>
</div>

</div>

</body>
</html>